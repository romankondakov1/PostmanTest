                  "});",
                  "",
                  "pm.test(\"Category id is 1\", function () {",
                  "    pm.expect(response.category.id).to.eql(1);",
                  "});",
                  "",
                  "",
                  "pm.collectionVariables.set(\"product_id\", response.id);"
